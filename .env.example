# ──────────────────────────────────────────────────────────────────────────────
# Stack metadata
# ──────────────────────────────────────────────────────────────────────────────
# Único na VPS — vira prefixo do router Traefik, container_name e volume
APP_NAME=disparos

# Domínio público apontado para o IP da VPS (A record)
DOMAIN=painelapi.online

# Nome EXATO da network externa do Traefik (já existe na VPS)
TRAEFIK_NETWORK=evolution-api-1i9c_default

# ──────────────────────────────────────────────────────────────────────────────
# Banco (gere com: openssl rand -hex 16)
# ──────────────────────────────────────────────────────────────────────────────
DB_NAME=disparos
DB_USER=disparos
DB_PASSWORD=trocar_openssl_rand_hex_16
DB_ROOT_PASSWORD=trocar_openssl_rand_hex_16

# ──────────────────────────────────────────────────────────────────────────────
# Secrets do app
# ──────────────────────────────────────────────────────────────────────────────
# JWT pra assinar cookies de sessão (gere com: openssl rand -hex 32)
JWT_SECRET=trocar_openssl_rand_hex_32

# Token que o Meta envia no GET /api/webhook/whatsapp pra verificar o webhook
# (você define esse valor aqui E na configuração do webhook no Meta App Dashboard)
WHATSAPP_WEBHOOK_TOKEN=trocar_token_qualquer_string_aleatoria

# ──────────────────────────────────────────────────────────────────────────────
# Facebook Embedded Signup (OAuth) — opcional, deixe vazio se não usar
# ──────────────────────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Opcional: openId que deve ser promovido a admin automaticamente
# ──────────────────────────────────────────────────────────────────────────────
OWNER_OPEN_ID=

# Identificador do app (usado pelo client Vite — pode deixar vazio)
VITE_APP_ID=
