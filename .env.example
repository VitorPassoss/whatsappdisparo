# ──────────────────────────────────────────────────────────────────────────────
# Stack metadata
# ──────────────────────────────────────────────────────────────────────────────
# Único na VPS — vira prefixo do router Traefik, container_name e volume
APP_NAME=disparos

# Domínio público apontado para o IP da VPS (A record)
DOMAIN=painelapi.online

# Nome EXATO da network externa do Traefik (já existe na VPS)
TRAEFIK_NETWORK=evolution-api-1i9c_default

# ──────────────────────────────────────────────────────────────────────────────
# Banco (gere com: openssl rand -hex 16)
# ──────────────────────────────────────────────────────────────────────────────
DB_NAME=disparos
DB_USER=disparos
DB_PASSWORD=trocar_openssl_rand_hex_16
DB_ROOT_PASSWORD=trocar_openssl_rand_hex_16

# ──────────────────────────────────────────────────────────────────────────────
# Secrets do app
# ──────────────────────────────────────────────────────────────────────────────
# JWT pra assinar cookies de sessão (gere com: openssl rand -hex 32)
# CRÍTICO: este precisa estar no .env pois é lido antes do banco abrir.
# Trocar este valor invalida todas as sessões em curso.
JWT_SECRET=trocar_openssl_rand_hex_32

# ──────────────────────────────────────────────────────────────────────────────
# Configs abaixo podem ficar vazias aqui — você edita pela UI em
# https://painelapi.online/admin/settings (logado como admin).
# Deixe preenchido só se quiser bootstrap inicial automatizado.
# ──────────────────────────────────────────────────────────────────────────────
WHATSAPP_WEBHOOK_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Opcional: openId promovido a admin automaticamente (em geral deixe vazio —
# o primeiro usuário que se registrar vira admin automaticamente).
OWNER_OPEN_ID=

# Identificador do app (usado pelo client Vite — pode deixar vazio)
VITE_APP_ID=
